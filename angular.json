{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "design-system": {
      "projectType": "library",
      "root": "libs/design-system",
      "sourceRoot": "libs/design-system/src",
      "prefix": "ds",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/design-system",
            "index": "libs/design-system/src/index.html",
            "main": "libs/design-system/src/main.ts",
            "tsConfig": "libs/design-system/tsconfig.lib.json",
            "assets": [],
            "styles": ["libs/design-system/src/styles/global.scss"],
            "scripts": []
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "port": 4400,
            "configDir": "libs/design-system/.storybook",
            "browserTarget": "design-system:build",
            "compodoc": false
          },
          "configurations": {
            "ci": { "quiet": true }
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "outputDir": "dist/storybook/design-system",
            "configDir": "libs/design-system/.storybook",
            "browserTarget": "design-system:build",
            "compodoc": false
          },
          "configurations": {
            "ci": { "quiet": true }
          }
        }
      }
    }
  }
}
