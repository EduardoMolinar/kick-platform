{
  "name": "design-system",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/design-system/src",
  "prefix": "ds",
  "projectType": "library",
  "tags": ["scope:design-system", "type:lib"],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/design-system/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": [
          "libs/design-system/**/*.ts",
          "libs/design-system/**/*.html"
        ]
      }
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/design-system/.storybook",
        "browserTarget": "design-system:build",
        "compodoc": false
      },
      "configurations": {
        "ci": { "quiet": true }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/design-system",
        "configDir": "libs/design-system/.storybook",
        "browserTarget": "design-system:build",
        "compodoc": false
      },
      "configurations": {
        "ci": { "quiet": true }
      }
    }
  }
}
