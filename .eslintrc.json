{
  "root": true,
  "ignorePatterns": ["**/*"],
  "plugins": ["@nx"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "@nx/enforce-module-boundaries": [
          "error",
          {
            "enforceBuildableLibDependency": true,
            "allow": [],
            "depConstraints": [
              {
                "sourceTag": "scope:design-system",
                "onlyDependOnLibsWithTags": []
              },
              {
                "sourceTag": "scope:shared",
                "onlyDependOnLibsWithTags": ["scope:shared"]
              },
              {
                "sourceTag": "scope:shell",
                "onlyDependOnLibsWithTags": [
                  "scope:design-system",
                  "scope:shared"
                ]
              },
              {
                "sourceTag": "scope:mfe-home",
                "onlyDependOnLibsWithTags": [
                  "scope:design-system",
                  "scope:shared"
                ]
              },
              {
                "sourceTag": "scope:mfe-live",
                "onlyDependOnLibsWithTags": [
                  "scope:design-system",
                  "scope:shared"
                ]
              },
              {
                "sourceTag": "scope:mfe-competition",
                "onlyDependOnLibsWithTags": [
                  "scope:design-system",
                  "scope:shared"
                ]
              },
              {
                "sourceTag": "scope:mfe-team",
                "onlyDependOnLibsWithTags": [
                  "scope:design-system",
                  "scope:shared"
                ]
              },
              {
                "sourceTag": "scope:mfe-profile",
                "onlyDependOnLibsWithTags": [
                  "scope:design-system",
                  "scope:shared"
                ]
              },
              {
                "sourceTag": "type:lib",
                "onlyDependOnLibsWithTags": ["type:lib"]
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "extends": ["plugin:@nx/typescript"],
      "rules": {}
    },
    {
      "files": ["*.js", "*.jsx"],
      "extends": ["plugin:@nx/javascript"],
      "rules": {}
    }
  ]
}
